{
  "name": "kg-explorer",
  "version": "0.1.0",
  "description": "Local-first knowledge graph explorer. Drop in YAML/JSON, get an interactive visual canvas.",
  "type": "module",
  "main": "./dist/lib/kg-explorer.umd.cjs",
  "module": "./dist/lib/kg-explorer.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/kg-explorer.js",
      "require": "./dist/lib/kg-explorer.umd.cjs",
      "types": "./dist/lib/index.d.ts"
    },
    "./styles.css": "./dist/lib/styles.css"
  },
  "files": [
    "dist/lib"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json --emitDeclarationOnly",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "knowledge-graph",
    "graph-editor",
    "visualization",
    "react-flow",
    "react-component",
    "json-to-graph",
    "yaml-graph",
    "interactive-graph",
    "local-first"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RishabhSinha07/kg-explorer"
  },
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {
    "@xyflow/react": "^12.6.0",
    "html-to-image": "^1.11.13",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
